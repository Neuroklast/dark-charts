{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "git": {
    "deploymentEnabled": true
  },
  "github": {
    "silent": true,
    "autoJobCancelation": true
  },
  "ignoreCommand": "bash -c 'if [[ \"$VERCEL_GIT_COMMIT_MESSAGE\" =~ \\[RELEASE\\] ]]; then exit 1; else exit 0; fi'",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/aggregate-charts",
      "schedule": "55 23 * * 0"
    },
    {
      "path": "/api/cron/sync-itunes-artwork",
      "schedule": "0 4 * * *"
    }
  ]
}