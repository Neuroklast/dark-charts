# ===========================================
# Dark Charts - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# --- Required ---

# PostgreSQL connection string (Vercel Postgres, Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/darkcharts"

# Secret key for signing JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=""

# Environment mode
NODE_ENV="development"

# --- Vercel Cron ---

# Secret for authenticating cron job requests (generate with: openssl rand -hex 16)
CRON_SECRET=""

# --- CORS ---

# Allowed origin for API requests (set to your frontend domain in production)
# Example: https://darkcharts.vercel.app
# Leave empty or "*" for development
ALLOWED_ORIGIN="*"

# --- Spotify API (for streaming charts) ---

# Server-side credentials (Client Credentials flow)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Frontend credentials (for user-facing OAuth, VITE_ prefix for Vite)
VITE_SPOTIFY_CLIENT_ID=""
VITE_SPOTIFY_CLIENT_SECRET=""

# --- Optional ---

# Vercel Blob Storage token (for album artwork uploads)
BLOB_READ_WRITE_TOKEN=""

# GitHub Spark environment flag (development only)
# VITE_IS_SPARK="false"
