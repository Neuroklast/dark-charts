# Spotify OAuth Configuration
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/oauth/callback

# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback

# OAuth Configuration
VITE_OAUTH_STATE_SECRET=your_random_state_secret_here

# Spotify API Configuration (for Artist Management)
VITE_SPOTIFY_API_BASE_URL=https://api.spotify.com/v1

# Odesli API Configuration
VITE_ODESLI_API_URL=https://api.song.link/v1-alpha.1

# Application Configuration
VITE_APP_URL=http://localhost:5173
