# ===========================================
# Dark Charts - Environment Variables
# ===========================================
# Copy to .env.local for Next.js development.

# --- Required ---

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

JWT_SECRET=""
NODE_ENV="development"

# --- Vercel Cron ---
CRON_SECRET=""
# Daily 04:00 UTC: /api/cron/sync-itunes-artwork (iTunes → R2 cover cache)

# --- CORS ---
ALLOWED_ORIGIN="*"

# --- Token-geschützte Data API (/api/v1/*) ---
# Statischer Bearer-Token für Server-zu-Server-Zugriff (optional neben JWT)
DATA_API_TOKEN=""

# --- Spotify ---
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=""

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# --- Cloudflare R2 (optional) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# --- Admin bootstrap (optional) ---
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_INIT_SECRET=""

# --- Legal / Impressum (required before public launch) ---
NEXT_PUBLIC_LEGAL_OPERATOR_NAME=""
NEXT_PUBLIC_LEGAL_FORM="Einzelunternehmen"
NEXT_PUBLIC_LEGAL_STREET=""
NEXT_PUBLIC_LEGAL_ZIP=""
NEXT_PUBLIC_LEGAL_CITY=""
NEXT_PUBLIC_LEGAL_COUNTRY="Deutschland"
NEXT_PUBLIC_LEGAL_EMAIL="legal@darkcharts.de"
NEXT_PUBLIC_PRIVACY_EMAIL="privacy@darkcharts.de"
NEXT_PUBLIC_LEGAL_PHONE=""
NEXT_PUBLIC_LEGAL_VAT_ID=""
NEXT_PUBLIC_LEGAL_REPRESENTATIVE=""

# --- Payments / Spotlight (planned) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Legacy Vite (migration fallback) ---
# VITE_SUPABASE_URL=""
# VITE_SUPABASE_ANON_KEY=""