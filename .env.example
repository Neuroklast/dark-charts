# Database Configuration (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxx"

# Spotify API
SPOTIFY_CLIENT_ID="your_spotify_client_id"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret"
SPOTIFY_REDIRECT_URI="http://localhost:5000/oauth/callback"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:5000/oauth/callback"

# iTunes/Odesli API
ITUNES_API_BASE_URL="https://itunes.apple.com"
ODESLI_API_BASE_URL="https://api.song.link/v1-alpha.1"

# JWT Secret for Session Management
JWT_SECRET="your_jwt_secret_key_here_change_in_production"

# Cron Job Configuration
RELEASE_SYNC_CRON="0 2 * * *"
ARTWORK_SYNC_CRON="0 3 * * *"

# Application Settings
NODE_ENV="development"
PORT="5000"
